{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "QRegu Website",
      "type": "node-terminal",
      "request": "launch",
      "command": "python3 -m http.server 8080",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "Serving HTTP on",
        "uriFormat": "http://localhost:8080",
        "action": "openExternally"
      }
    }
  ]
}